--=== DUPLICATION SYSTEM ===--
local DupSystem = {
    IsAutoActive = false,
    DupCount = 0,
    TotalDups = 0,
    Connections = {},
    SafetyChecks = 0,
    IsKeyActive = false
}

function DupSystem:UpdateProgress()
    local progress = (self.DupCount / CONFIG.SETTINGS.MAX_DUP_COUNT) * 100
    ProgressBar.Size = UDim2.new(0, (progress / 100) * (ProgressFrame.AbsoluteSize.X), 1, 0)
end

function DupSystem:FireTrap()
    if not self.IsKeyActive then return false end
    if not ReplicatedStorage:FindFirstChild("Remotes") then return false end
    local remotes = ReplicatedStorage.Remotes
    if not remotes:FindFirstChild("Trap") then return false end

    local success = pcall(function()
        remotes.Trap:FireServer()
    end)

    return success
end

function DupSystem:StartManualDup()
    if not self.IsKeyActive then 
        StatusLabel.Text = "❌ Требуется активация ключа"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        return 
    end
    if self.IsAutoActive then return end

    StatusLabel.Text = "🔄 Starting duplication..."
    StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)

    self.DupCount = 0

    for i = 1, CONFIG.SETTINGS.MAX_DUP_COUNT do
        if not self:FireTrap() then break end

        self.DupCount = i
        self.TotalDups = self.TotalDups + 1
        self:UpdateProgress()

        StatusLabel.Text = string.format("📦 Duplication: %d/%d", i, CONFIG.SETTINGS.MAX_DUP_COUNT)

        if CONFIG.SETTINGS.RANDOM_DELAY then
            task.wait(math.random(5, 15) / 100)
        else
            task.wait(CONFIG.SETTINGS.AUTO_DELAY)
        end
    end

    StatusLabel.Text = string.format("✅ Duplication complete! Total: %d", self.TotalDups)
    StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)

    task.delay(3, function()
        if not self.IsAutoActive then
            ProgressBar.Size = UDim2.new(0, 0, 1, 0)
            StatusLabel.Text = "✅ System ready"
        end
    end)
end

function DupSystem:ToggleAutoDup()
    if not self.IsKeyActive then 
        StatusLabel.Text = "❌ Требуется активация ключа"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        return 
    end
    
    self.IsAutoActive = not self.IsAutoActive

    if self.IsAutoActive then
        AutoDupButton.Text = "⚡ AUTO-DUP: ON"
        AutoDupButton.TextColor3 = Color3.fromRGB(0, 255, 100)
        StatusLabel.Text = "🤖 Auto-duplication activated"
        StatusLabel.TextColor3 = Color3.fromRGB(0, 200, 255)

        self.Connections.AutoDup = game:GetService("RunService").Heartbeat:Connect(function()
            self:FireTrap()
            self.TotalDups = self.TotalDups + 1

            if self.TotalDups % 10 == 0 then
                StatusLabel.Text = string.format("🤖 Auto-duplication: %d+", self.TotalDups)
            end
        end)

    else
        AutoDupButton.Text = "⚡ AUTO-DUP: OFF"
        AutoDupButton.TextColor3 = Color3.fromRGB(255, 100, 100)
        StatusLabel.Text = "✅ Auto-duplication stopped"

        if self.Connections.AutoDup then
            self.Connections.AutoDup:Disconnect()
            self.Connections.AutoDup = nil
        end

        task.delay(2, function()
            StatusLabel.Text = "✅ System ready"
            StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
        end)
    end
end

function DupSystem:QuickDup()
    if not self.IsKeyActive then 
        StatusLabel.Text = "❌ Требуется активация ключа"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        return 
    end
    
    StatusLabel.Text = "⚡ Quick duplication..."
    StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 100)

    for i = 1, 10 do
        self:FireTrap()
        self.TotalDups = self.TotalDups + 1
        task.wait(0.02)
    end

    StatusLabel.Text = string.format("⚡ Quick duplication: +10 | Total: %d", self.TotalDups)

    task.delay(2, function()
        if not self.IsAutoActive then
            StatusLabel.Text = "✅ System ready"
            StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
        end
    end)
end

function DupSystem:EmergencyStop()
    self.IsAutoActive = false
    AutoDupButton.Text = "⚡ AUTO-DUP: OFF"
    AutoDupButton.TextColor3 = Color3.fromRGB(255, 100, 100)

    StatusLabel.Text = "🚨 EMERGENCY STOP"
    StatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)

    for _, conn in pairs(self.Connections) do
        conn:Disconnect()
    end
    self.Connections = {}

    ProgressBar.Size = UDim2.new(0, 0, 1, 0)
end

