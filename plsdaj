-- Функция для сохранения данных ключей
function KEY_SYSTEM:SaveKeyData()
    local saveData = {
        usedKeys = self.USED_KEYS,
        activationTime = self.ACTIVATION_TIME
    }
    pcall(function()
        writefile("ultimate_dup_keys.txt", HttpService:JSONEncode(saveData))
    end)
end

-- Функция для загрузки данных ключей
function KEY_SYSTEM:LoadKeyData()
    pcall(function()
        if isfile("ultimate_dup_keys.txt") then
            local data = readfile("ultimate_dup_keys.txt")
            local saveData = HttpService:JSONDecode(data)
            self.USED_KEYS = saveData.usedKeys or {}
            self.ACTIVATION_TIME = saveData.activationTime
        end
    end)
end

-- Проверка активного ключа
function KEY_SYSTEM:IsKeyActive()
    if not self.ACTIVATION_TIME then return false end
    
    local currentTime = os.time()
    local elapsedTime = currentTime - self.ACTIVATION_TIME
    
    return elapsedTime < self.KEY_DURATION
end

-- Активация ключа
function KEY_SYSTEM:ActivateKey(key)
    key = string.upper(key:gsub("%s+", ""))
    
    -- Проверка формата ключа
    if not string.match(key, "^UD2024%-KEY%d+%-[A-Z0-9]+$") then
        return false, "❌ Неверный формат ключа"
    end
    
    -- Проверка существования ключа
    local keyExists = false
    for _, validKey in ipairs(self.ACTIVE_KEYS) do
        if key == validKey then
            keyExists = true
            break
        end
    end
    
    if not keyExists then
        return false, "❌ Ключ не существует"
    end
    
    -- Проверка использования ключа
    for _, usedKey in ipairs(self.USED_KEYS) do
        if usedKey.key == key then
            local currentTime = os.time()
            local timeLeft = usedKey.activationTime + self.KEY_DURATION - currentTime
            
            if timeLeft > 0 then
                -- Ключ уже активен
                self.ACTIVATION_TIME = usedKey.activationTime
                self:SaveKeyData()
                return true, string.format("✅ Ключ уже активен! Осталось: %d сек", timeLeft)
            else
                -- Удаляем просроченный ключ
                for i = #self.USED_KEYS, 1, -1 do
                    if self.USED_KEYS[i].key == key then
                        table.remove(self.USED_KEYS, i)
                    end
                end
            end
        end
    end
    
    -- Активация нового ключа
    self.ACTIVATION_TIME = os.time()
    table.insert(self.USED_KEYS, {
        key = key,
        activationTime = self.ACTIVATION_TIME
    })
    
    self:SaveKeyData()
    return true, "✅ Ключ успешно активирован на 5 минут!"
end

